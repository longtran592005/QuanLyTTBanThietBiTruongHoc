<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <connectionStrings>
    <add name="SchoolDeviceStoreDB"
         connectionString="Data Source=|DataDirectory|\SchoolDeviceStore.db;Version=3;"
         providerName="System.Data.SQLite" />
  </connectionStrings>
  <appSettings>
    <add key="SeedDemoDataOnStartup" value="true" />
  </appSettings>
</configuration>
