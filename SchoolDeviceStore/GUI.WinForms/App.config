<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <connectionStrings>
    <!-- SQLite-only portable setup: app creates/uses SQLite in LocalAppData\SchoolDeviceStore\Data -->
    <add name="SchoolDeviceStoreDB" connectionString="Data Source=|DataDirectory|\SchoolDeviceStore.db;Version=3;" providerName="System.Data.SQLite" />
  </connectionStrings>
  <appSettings>
    <add key="SeedDemoDataOnStartup" value="true" />
  </appSettings>
</configuration>